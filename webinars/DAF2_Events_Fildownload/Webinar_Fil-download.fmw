FACTORY_DEF * TeeFactory    FACTORY_NAME $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_INPUT    INPUT  FEATURE_TYPE "$(PointCloudLASClassifier_WORKSPACE_NAME)_AttributeValueMapper_OUTPUT"    OUTPUT FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_INPUTLINE
FACTORY_DEF {*} TestFactory FACTORY_NAME { $(PointCloudLASClassifier_WORKSPACE_NAME)_PC } INPUT FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_INPUTLINE TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_classification<closeparen>,$(PointCloudLASClassifier_WORKSPACE_NAME)_PC) = 0 ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_0 FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_0-Created<openparen>NeverClassified<closeparen> TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_classification<closeparen>,$(PointCloudLASClassifier_WORKSPACE_NAME)_PC) = 1 ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_1 FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_1-Unclassified TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_classification<closeparen>,$(PointCloudLASClassifier_WORKSPACE_NAME)_PC) = 2 ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_2 FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_2-Ground TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_classification<closeparen>,$(PointCloudLASClassifier_WORKSPACE_NAME)_PC) = 3 ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_3 FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_3-LowVegetation TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_classification<closeparen>,$(PointCloudLASClassifier_WORKSPACE_NAME)_PC) = 4 ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_4 FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_4-MediumVegetation TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_classification<closeparen>,$(PointCloudLASClassifier_WORKSPACE_NAME)_PC) = 5 ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_5 FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_5-HighVegetation TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_classification<closeparen>,$(PointCloudLASClassifier_WORKSPACE_NAME)_PC) = 6 ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_6 FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_6-Building TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_classification<closeparen>,$(PointCloudLASClassifier_WORKSPACE_NAME)_PC) = 7 ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_7 FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_7-LowPoint<openparen>Noise<closeparen> TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_classification<closeparen>,$(PointCloudLASClassifier_WORKSPACE_NAME)_PC) = 8 ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_8 FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_8-ModelKeyPoint<openparen>MassPoint<closeparen> TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_classification<closeparen>,$(PointCloudLASClassifier_WORKSPACE_NAME)_PC) = 9 ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_9 FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_9-Water TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_classification<closeparen>,$(PointCloudLASClassifier_WORKSPACE_NAME)_PC) = 10 ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_10 FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_10-Reserved<space>for<space>ASPRS<space>Definition TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_classification<closeparen>,$(PointCloudLASClassifier_WORKSPACE_NAME)_PC) = 11 ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_11 FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_11-Reserved<space>for<space>ASPRS<space>Definition TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_classification<closeparen>,$(PointCloudLASClassifier_WORKSPACE_NAME)_PC) = 12 ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_12 FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_12-OverlapPoints TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_classification<closeparen>,$(PointCloudLASClassifier_WORKSPACE_NAME)_PC) >= 13 ENCODED } BOOLEAN_OPERATOR OR OUTPUT PASSED_13 FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_13more-Reserved<space>for<space>ASPRS<space>Definition OUTPUT FAILED FEATURE_TYPE $(PointCloudLASClassifier_WORKSPACE_NAME)_PC_<lt>UNFILTERED<gt>
