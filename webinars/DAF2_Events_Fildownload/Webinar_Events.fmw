FACTORY_DEF {*} TeeFactory    FACTORY_NAME { CoordinateSystemSetter }    INPUT  FEATURE_TYPE AttributeCreator_12_OUTPUT    OUTPUT { FEATURE_TYPE CoordinateSystemSetter_OUTPUT         @CoordSys("@EvaluateExpression(FDIV,STRING,<at>Value<openparen>byg404Koordinat.crs<closeparen>,CoordinateSystemSetter)")          }
# -------------------------------------------------------------------------
# Assumption is that the workspace temp dir has been already set and created.  See controldefs.cpp - ControlDefs::writeVisualizerTempDir
DEFAULT_MACRO WORKSPACE_TEMP_DIR
DEFAULT_MACRO FME_LAUNCH_VIEWER_APP NO
INCLUDE [    set safeName "[regsub -all {[^a-zA-Z0-9]} {Opdaterade_bygninger} _]_[expr round(rand() * 1000000)]_[clock clicks  -milliseconds]";    puts "MACRO SAFE_FFS_NAME $safeName"; ]
INCLUDE [    if {{NoReduction} == {NoReduction} &&        {NO_THINNING} == {NO_THINNING}} {       puts "MACRO Opdaterade_bygninger_daa17a07_5720_4cc7_8636_c222b3f9e8781_LARGE_GEOMETRY_DATA_STORAGE REFERENCE";    } else {       puts "MACRO Opdaterade_bygninger_daa17a07_5720_4cc7_8636_c222b3f9e8781_LARGE_GEOMETRY_DATA_STORAGE FULL";    }; ]
INCLUDE [    if {{$(FME_LAUNCH_VIEWER_APP)} != {NO}} {       puts "MACRO ENABLE_RECORDING *";    } else {       puts "MACRO ENABLE_RECORDING _NOT_THIS_TIME_";    }; ]
FACTORY_DEF {*} InspectorFactory    FACTORY_NAME { Opdaterade_bygninger_Prepper }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE CoordinateSystemSetter_OUTPUT    GROUP_ATTRIBUTE __inspector_feature_type_attr__    GROUP_ATTRIBUTE_PREFIX { Opdaterade_bygninger }    RASTER_REDUCTION { NoReduction }    POINT_CLOUD_REDUCTION { NO_THINNING }    OUTPUT { RESULT FEATURE_TYPE __viewme__       }
# Now route all the features into the recorder, changing their
# feature type to the transformer name so that they view nicely
DEFAULT_MACRO VISUALIZER_FEATURE_FILE $(WORKSPACE_TEMP_DIR)/$(SAFE_FFS_NAME).ffs
DEFAULT_MACRO VISUALIZER_CREATE_SPATIAL_INDEX NO
# [PR#45549] The Data Inspector will limit the maximum number of features
# it reads on WIN32, so we will correspondingly limit the number of
# features we record here using the MAX_FEATURES_TO_RECORD directive.
FACTORY_DEF {$(ENABLE_RECORDING)} RecorderFactory    FACTORY_NAME { Opdaterade_bygninger_Recorder }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT FEATURE_TYPE __viewme__       _wb_termination_feature Yes       @FeatureType(TERMINATOR_@Value(_wb_termination_xformer))    INPUT FEATURE_TYPE __viewme__       @FeatureType(@Value(__inspector_feature_type_attr__))       @RemoveAttributes(__inspector_feature_type_attr__)    FEATURE_FILE { "$(VISUALIZER_FEATURE_FILE)" }    STORE_SCANNED_SCHEMA YES    NORMALIZE_LIST_ATTRIBUTES_ON_SCHEMA YES    CREATE_SPATIAL_INDEX { "$(VISUALIZER_CREATE_SPATIAL_INDEX)" }    INSPECTOR { "$(VISUALIZER_CREATE_SPATIAL_INDEX)" }    FSC_SCHEMA { byg404Koordinat.crs,buffer,_timestamp,datetime,_response_body,buffer,entityname,buffer,eventaction,buffer,eventid,buffer,object_id,buffer,object_status,buffer,json_type,buffer,json_index,uint32,id_lokalId,buffer,datafordelerOpdateringstid,buffer }    MODE RECORD    STORE_SCANNED_METADATA    RECORD_DIRECTLY_TO_DISK YES    MAX_FEATURES_TO_RECORD WIN32 2000000    LARGE_GEOMETRY_DATA_STORAGE { $(Opdaterade_bygninger_daa17a07_5720_4cc7_8636_c222b3f9e8781_LARGE_GEOMETRY_DATA_STORAGE) }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { Opdaterade_bygninger_Nuker }    INPUT FEATURE_TYPE __viewme__
