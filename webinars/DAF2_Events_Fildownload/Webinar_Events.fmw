FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { VariableSetter_3 }    INPUT  FEATURE_TYPE Tester_8_FAILED    ATTR_ACTION { "" $(FME_UUID_SAFE) SET_TO "$(VariableSetter_3_VALUE)" }    OUTPUT { OUTPUT FEATURE_TYPE VariableSetter_3_OUTPUT        @GlobalVariable($(VariableSetter_3_VAR),fme_attribute_name,$(FME_UUID_SAFE))        @RemoveAttributes($(FME_UUID_SAFE))         }
