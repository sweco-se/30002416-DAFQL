FACTORY_DEF {*} TeeFactory    FACTORY_NAME { Junction_11 }    INPUT  FEATURE_TYPE VariableSetter_2_OUTPUT    INPUT  FEATURE_TYPE VariableSetter_3_OUTPUT    OUTPUT { FEATURE_TYPE Junction_11_Output         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { Junction_8 }    INPUT  FEATURE_TYPE Junction_9_Output    INPUT  FEATURE_TYPE Junction_11_Output    OUTPUT { FEATURE_TYPE Junction_8_Output         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} JSONQueryFactory    FACTORY_NAME { JSONFragmenter_5 }    INPUT  FEATURE_TYPE Junction_8_Output    MODE EXPLODE    EXPLODE_FORMAT { JSON }    REJECT_EMPTY_LISTS { YES }    EXTRACT_ATTR { Yes }    JSON_ATTR { "_response_body" }    READ_FROM_FILE { NO }    FILEPATH_OR_URL { "<Unused>" }    OUTPUT_ATTRIBUTE { "<Unused>" }    EXPLODE_QUERY { "json<openbracket><quote>nodes<quote><closebracket><openbracket>*<closebracket>" }    RECURSIVE_FLATTEN { YES }    OUTPUT { EXPLODED FEATURE_TYPE JSONFragmenter_5_FRAGMENTS        }    OUTPUT { REJECTED FEATURE_TYPE JSONFragmenter_5_<REJECTED>        }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "nodes<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO AttributeRemover_LIST_FUNC }    } else {        puts "MACRO AttributeRemover_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { AttributeRemover }    INPUT  FEATURE_TYPE JSONFragmenter_5_FRAGMENTS    OUTPUT { FEATURE_TYPE AttributeRemover_OUTPUT        @RemoveAttributes(fme_encoded,_copynum,_creation_instance,_gql,_gql_rest,_result_datetime,_v_cursor,json_index,json_type,pageInfo.endCursor,pageInfo.hasNextPage,query.RegistreringFra,query.VirkningFra)        $(AttributeRemover_LIST_FUNC)         }
# -------------------------------------------------------------------------
FACTORY_DEF {*} SortFactory    FACTORY_NAME { Sorter }    INPUT  FEATURE_TYPE AttributeRemover_OUTPUT    SORT_ALPHA_AS_UTF8 { YES }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    SORT_BY { object_datafordelerRowVersion NATURAL ASCENDING NON_VALUES_AFTER_VALUES }    OUTPUT { SORTED FEATURE_TYPE Sorter_SORTED          }
# -------------------------------------------------------------------------
FACTORY_DEF {*} CounterFactory    FACTORY_NAME { Counter }    FLUSH_WHEN_GROUPS_CHANGE { <Unused> }    START { "0" }    SCOPE { Global }    DOMAIN { "@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>object_datafordelerRowVersion<closeparen>,Counter)" }    COUNT_ATTR { "groupId" }    GROUP_ID_ATTR { "" }    INPUT  FEATURE_TYPE Sorter_SORTED    OUTPUT { OUTPUT FEATURE_TYPE Counter_OUTPUT        }    OUTPUT { REJECTED FEATURE_TYPE Counter_<REJECTED>        }
# -------------------------------------------------------------------------
FACTORY_DEF {CONNECTED} CreationFactory    FACTORY_NAME { AttributeCreator_4_Creator }    OUTPUT { FEATURE_TYPE AttributeCreator_4_____CREATED______ }
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { AttributeCreator_4 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT { FEATURE_TYPE AttributeCreator_4_____CREATED______ }    INPUT  FEATURE_TYPE Counter_OUTPUT    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "object_datafordelerRowId" "SET_TO" "<quote><at>Value<openparen>object_datafordelerRowId<closeparen><quote>" "buffer" }      ATTR_ACTION { "" "groupId" "SET_TO" "<at>Evaluate<openparen><at>floor<openparen><at>Value<openparen>groupId<closeparen><solidus>50<comma>0<closeparen><closeparen>" "real64" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeCreator_4_OUTPUT        }
