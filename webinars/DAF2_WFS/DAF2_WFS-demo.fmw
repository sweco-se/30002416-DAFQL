MACRO FeatureReader_OUTPUT_PORTS_ENCODED bygning_current
MACRO FeatureReader_DIRECTIVES CONTINUE_ON_GEOM_ERROR,no,COORDINATE_SYSTEM,,CREATE_ENTITY_RESOLVER,Yes,DISABLE_EXTERNAL_ENTITY_PROCESSING,yes,EXPOSE_ATTRS_GROUP,,FILE_TYPE,Feature<space>Paths,IGNORE_DATASET_EXTERNAL_DTD,no,MAX_SCHEMA_SCAN_FEATURES,,READER_SETTINGS,,SPATIAL_GROUP,,SUPPORTED_READER_ARCHIVE_EXTENSIONS,xml.gz<comma>gml.gz,USE_SEARCH_ENVELOPE,NO,VALIDATE_DATASET,no,VALIDATE_XFMAP,no,XFMAP_FEATURE_PATHS,FeatureCollection<lt>solidus<gt>member<lt>solidus<gt>bygning_current,XFMAP_FEATURE_PATHS_EXCEPT,,XFMAP_FEATURE_PATHS_STRUCTURE,<lt>lt<gt>structure<lt>space<gt><lt>space<gt><lt>lf<gt>separator=<lt>quote<gt>.<lt>quote<gt><lt>space<gt><lt>lf<gt>map-empty-elements=<lt>quote<gt>yes<lt>quote<gt><lt>space<gt><lt>lf<gt>matched-prefix=<lt>quote<gt>attributes<lt>quote<gt><lt>space<gt><lt>lf<gt>matched-attributes=<lt>quote<gt>yes<lt>quote<gt><lt>space<gt><lt>lf<gt>cardinality=<lt>quote<gt>+<lt>opencurly<gt>?<lt>closecurly<gt><lt>quote<gt><lt>lf<gt>except-expression=<lt>quote<gt><lt>quote<gt><lt>lf<gt>structure-prefix=<lt>quote<gt><lt>quote<gt><lt>lf<gt>child-position-attribute=<lt>quote<gt><lt>quote<gt><lt>lf<gt>attribute-identifier=<lt>quote<gt><lt>quote<gt><lt>lf<gt>ui-mode=<lt>quote<gt>basic<lt>quote<gt><lt>solidus<gt><lt>gt<gt>,XFMAP_FEATURE_PATHS_SUB_FRAGMENTS,,XML_EXPOSE_FORMAT_ATTRS,
# Always provide an INTERACTION, otherwise the factory defaults to ENVELOPE_INTERSECTS
INCLUDE [if { ( {NONE} == {<Unused>} ) || ( {($INTERACT)} == {} ) } {             puts {MACRO FCTQUERY_INTERACTION_LINE FCTQUERY_INTERACTION NONE};          } else {             puts {MACRO FCTQUERY_INTERACTION_LINE FCTQUERY_INTERACTION "NONE"};          }         ]
# Consolidate the attribute merge options to what the factory expects
DEFAULT_MACRO FeatureReader_COMBINE_ATTRS
INCLUDE [       if { {RESULT_ONLY} == {MERGE} } {          puts "MACRO FeatureReader_COMBINE_ATTRS <Unused>";       } else {          puts "MACRO FeatureReader_COMBINE_ATTRS RESULT_ONLY";       };    ]
INCLUDE [    puts {DEFAULT_MACRO FeatureReaderDataset_FeatureReader C:<backslash>Users<backslash>SEHHAN<backslash>OneDrive<space>-<space>Sweco<space>AB<backslash>FME<backslash>DAF2<backslash>WFS<backslash>BBR_WFS_download.gml}; ]
FACTORY_DEF {CONNECTED} CreationFactory    FACTORY_NAME { FeatureReader_Creator }    OUTPUT { FEATURE_TYPE FeatureReader_____CREATED______ }
FACTORY_DEF {*} QueryFactory    FACTORY_NAME { FeatureReader }    INPUT { FEATURE_TYPE FeatureReader_____CREATED______ }    INPUT INITIATOR FEATURE_TYPE HTTPCaller_7_Output    $(FCTQUERY_INTERACTION_LINE)    CLIP_TO_INITIATOR_ENVELOPE { "NO" }    COMBINE_ATTRIBUTES  { $(FeatureReader_COMBINE_ATTRS) }    IGNORE_NULLS        { <Unused> }    REJECT_POINTS       { YES }    QUERYFCT_ATTRIBUTE_PREFIX { <Unused> }    COMBINE_GEOMETRY    { RESULT_ONLY }    ENABLE_CACHE        { NO }    QUERYFCT_TABLE_SEPARATOR { SPACE }    READER_TYPE         { XML  }    READER_DATASET      { "$(FeatureReaderDataset_FeatureReader)" }    QUERYFCT_IDS        { "bygning_current" }    QUERYFCT_IDS_FORMAT WWJD_PARTS    READER_DIRECTIVES   { METAFILE,XML }    QUERYFCT_OUTPUT     { "BASED_ON_CONNECTIONS" }    QUERYFCT_ADD_SCHEMA { "NO" }    QUERYFCT_USE_SCHEMA_CACHE { "YES" }    QUERYFCT_INITIATOR_FIRST_OUTPUT { "default" }    QUERYFCT_DEDUPE_GEOM YES    CONTINUE_ON_READER_ERROR YES    ORDER_RESULTS { "No" }    QUERYFCT_RESULT_TAGS { $(FeatureReader_OUTPUT_PORTS_ENCODED) }    QUERYFCT_SET_FME_FEATURE_TYPE YES    QUERYFCT_SET_FME_META_ATTRS YES    READER_PARAMS_WWJD     { $(FeatureReader_DIRECTIVES) }    TREAT_READER_PARAM_AMPERSANDS_AS_LITERALS YES    HONOR_INITIATOR_COORDSYS YES    OUTPUT { READER_ERROR FEATURE_TYPE FeatureReader_<REJECTED>           }    OUTPUT bygning_current FEATURE_TYPE FeatureReader_bygning_current
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME FeatureReader_<Rejected> INPUT FEATURE_TYPE FeatureReader_<REJECTED>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, FeatureReader<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Log<space>and<space>Troubleshoot<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
# -------------------------------------------------------------------------
FACTORY_DEF {*} StringValueFactory    FACTORY_NAME { AttributeSplitter }    INPUT  FEATURE_TYPE FeatureReader_bygning_current    FACTORY_MODE ATTRIBUTE_SPLITTER    ATTR_NAME { byg404Koordinat.Point.pos }       DELIMITER { <space> }       FIELD_QUALIFIER { "" }       TRIM_TYPE { BOTH }       LIST_NAME { _coordinateList }       DROP_EMPTY_PARTS { NO }    OUTPUT { OUTPUT FEATURE_TYPE AttributeSplitter_OUTPUT          }
# -------------------------------------------------------------------------
MACRO VertexCreator_RemoveSourceAttrX
MACRO VertexCreator_RemoveSourceAttrY
MACRO VertexCreator_RemoveSourceAttrZ
INCLUDE [ set sourceAttrX {@EvaluateExpression(FDIV,FLOAT,<at>Value<openparen>_coordinateList<opencurly>0<closecurly><closeparen>,VertexCreator)};           set sourceAttrY {@EvaluateExpression(FDIV,FLOAT,<at>Value<openparen>_coordinateList<opencurly>1<closecurly><closeparen>,VertexCreator)};           set sourceAttrZ {};           if {{No} == {Yes} } {                if {[regexp {@EvaluateExpression\(FDIV,FLOAT,<at>Value<openparen>(.*?)<closeparen>} "$sourceAttrX" dummy geomSrcAttrX]} {                   puts "MACRO VertexCreator_RemoveSourceAttrX @RemoveAttributes($geomSrcAttrX)";                };                if {[regexp {@EvaluateExpression\(FDIV,FLOAT,<at>Value<openparen>(.*?)<closeparen>} "$sourceAttrY" dummy geomSrcAttrY]} {                   puts "MACRO VertexCreator_RemoveSourceAttrY @RemoveAttributes($geomSrcAttrY)";                };                if {[regexp {@EvaluateExpression\(FDIV,FLOAT,<at>Value<openparen>(.*?)<closeparen>} "$sourceAttrZ" dummy geomSrcAttrZ]} {                   puts "MACRO VertexCreator_RemoveSourceAttrZ @RemoveAttributes($geomSrcAttrZ)";                };           }; ]
FACTORY_DEF {*} VertexCreatorFactory    FACTORY_NAME { VertexCreator }    INPUT  FEATURE_TYPE AttributeSplitter_OUTPUT    MODE { REPLACE }    INDEX { "<Unused>" }    CONTINUE_ON_ERROR YES    XVAL { "@EvaluateExpression(FDIV,FLOAT,<at>Value<openparen>_coordinateList<opencurly>0<closecurly><closeparen>,VertexCreator)" }    YVAL { "@EvaluateExpression(FDIV,FLOAT,<at>Value<openparen>_coordinateList<opencurly>1<closecurly><closeparen>,VertexCreator)" }    ZVAL { "" }    USE_EXISTING_Z YES    ALLOW_DUPLICATES { "<Unused>" }    CLOSE_LINES { "<Unused>" }    ADD_MODE_VERSION 6    MISSING_VAL_MODE { <Unused> }    COMPUTE_MEASURES_MODE { CONTINUOUS }    COMMAND_PARM_EVALUATION SINGLE_PASS    OUTPUT { REJECTED FEATURE_TYPE VertexCreator_<REJECTED>        }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {Logger_813b0c50_bd70_4f4d_a146_a749816fab260} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME Logger
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { Logger_Logger }    INPUT  FEATURE_TYPE VertexCreator_<REJECTED>    OUTPUT { FEATURE_TYPE Logger_LOGGED                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>Feature is:","20","20","",INFO,LOG_ONLY,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "Logger LOGGED Transformer Output Nuker"   INPUT FEATURE_TYPE Logger_LOGGED
# -------------------------------------------------------------------------
FACTORY_DEF {CONNECTED} CreationFactory    FACTORY_NAME { XMLFragmenter_Creator }    OUTPUT { FEATURE_TYPE XMLFragmenter_____CREATED______ }
