Tcl2 proc $(GraphQLtoJSON_WORKSPACE_NAME)_ParameterFetcher_doFetch {} {    foreach {name val} {"_gql {$($(GraphQLtoJSON_WORKSPACE_NAME)_GQL$encode)} _gql_rest {$($(GraphQLtoJSON_WORKSPACE_NAME)_GQL$encode)}"} {         if { [string match {*<at>*} $val] == 1 } {             set val [FME_Execute EvaluateExpression {STRING} $val {$(GraphQLtoJSON_WORKSPACE_NAME)_ParameterFetcher}];         } elseif {[string match {*FME_CONDITIONAL*} $val] == 1} {             set val [FME_Execute EvaluateExpression {STRING} $val {$(GraphQLtoJSON_WORKSPACE_NAME)_ParameterFetcher}];         } else {             set val [FME_DecodeTextOrAttr $val];         };       FME_SetAttribute [FME_DecodeText $name] $val    } }
