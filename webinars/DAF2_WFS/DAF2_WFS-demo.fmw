# First determine which function we are going to be using -- we can do
# this statically at parse time for efficiency sake
MACRO GeometryReplacer_3_SetTempAttr
MACRO GeometryReplacer_3_Function
MACRO GeometryReplacer_3_RemoveTempAttr
MACRO GeometryReplacer_3_RemoveSourceAttr
INCLUDE [ set sourceText {@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>GMLGeom<closeparen>,GeometryReplacer_3)};           set decodedText [FME_DecodeText "$sourceText"];           if ![regexp {@EvaluateExpression\([^)]*STRING_ENCODED,@Value\(([^()]*)\),[^()]*\)} "$decodedText" dummy geomSrcAttr] {               puts "MACRO GeometryReplacer_3_SetTempAttr @SupplyAttributes(ENCODED,__GeometryReplacerTemp__,\"$sourceText\")";               puts "MACRO GeometryReplacer_3_RemoveTempAttr @RemoveAttributes(__GeometryReplacerTemp__)";               set geomSrcAttr __GeometryReplacerTemp__;           } elseif {{Yes} == {Yes} } {                puts "MACRO GeometryReplacer_3_RemoveSourceAttr @RemoveAttributes(\"$geomSrcAttr\")";           };           if {{GML} == {fmebinary} } {               puts "MACRO GeometryReplacer_3_Function @Geometry(FROM_ATTRIBUTE_BINARY,\"$geomSrcAttr\")";           } elseif {{GML} == {fmehex} } {               puts "MACRO GeometryReplacer_3_Function @Geometry(FROM_ATTRIBUTE_BINARY_HEX,\"$geomSrcAttr\")";           } elseif {{GML} == {fmexml} } {               puts "MACRO GeometryReplacer_3_Function @Geometry(FROM_ATTRIBUTE,\"$geomSrcAttr\")";           } elseif {{GML} == {fmexmlencoded} } {               puts "MACRO GeometryReplacer_3_Function @Geometry(FROM_ENCODED_STRING,&\"$geomSrcAttr\")";           } elseif {{GML} == {polyline} } {               puts "MACRO GeometryReplacer_3_Function @Geometry(FROM_ATTRIBUTE_POLYLINE,\"$geomSrcAttr\")";           } elseif {{GML} == {wkt} } {               puts "MACRO GeometryReplacer_3_Function @OGCGeometry(from_attribute,GML,\"$geomSrcAttr\",<Unused>)";           } elseif {{GML} == {wkb} ||                      {GML} == {wkbhex} } {               puts "MACRO GeometryReplacer_3_Function @OGCGeometry(from_attribute,GML,\"$geomSrcAttr\")";           } elseif {{GML} == {GEOJSON} ||                     {GML} == {ESRIJSON} } {               puts "MACRO GeometryReplacer_3_Function @JSONGeometry(FROM_ATTRIBUTE,GML,\"$geomSrcAttr\")";           } elseif {{GML} == {GEORSS} } {               puts "MACRO GeometryReplacer_3_Function @GeoRSSGeometry(FROM_ATTRIBUTE,\"$geomSrcAttr\")";           } elseif {{GML} == {KML} } {               puts "MACRO GeometryReplacer_3_Function @KMLGeometry(FROM_ATTRIBUTE,\"$geomSrcAttr\")";           } elseif {{GML} == {GML} } {               puts "MACRO GeometryReplacer_3_Function @GMLGeometry(FROM_ATTRIBUTE,\"$geomSrcAttr\",)";           } elseif {{GML} == {geohash} } {               puts "MACRO GeometryReplacer_3_Function @GeoHash(FROM_ATTRIBUTE,\"$geomSrcAttr\",<Unused>)";           } elseif {{GML} == {ogeosms} ||                     {GML} == {geosms}  ||                     {GML} == {geo} } {               puts "MACRO GeometryReplacer_3_Function @OGCGeometry(from_attribute,GML,\"$geomSrcAttr\")";           } elseif {{GML} == {mgrs}} {               puts "MACRO GeometryReplacer_3_Function @MGRS(FROM_MGRS, <Unused>, <Unused>,\"@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>GMLGeom<closeparen>,GeometryReplacer_3)\")"           } elseif {{GML} == {mssql} } {               puts "MACRO GeometryReplacer_3_Function @SerializeGeometry(from_attribute,GML,\"$geomSrcAttr\",<Unused>)";           } elseif {{GML} == {iso6709} } {               puts "MACRO GeometryReplacer_3_Function @GeographicPoint(FROM_ATTRIBUTE,\"$geomSrcAttr\")";           } elseif {{GML} == {qlikmaps} } {               puts "MACRO GeometryReplacer_3_Function @Geometry(FROM_ATTRIBUTE_QLIKMAPS_POLYLINE,\"$geomSrcAttr\")";           }; ]
FACTORY_DEF {*} ExecuteFunctionFactory    FACTORY_NAME { GeometryReplacer_3_Rejector }    COMMAND_PARM_EVALUATION SINGLE_PASS    PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT    INPUT  FEATURE_TYPE AttributeCreator_5_OUTPUT    $(GeometryReplacer_3_SetTempAttr)    FUNCTION_DEFINITION { $(GeometryReplacer_3_Function) }    OUTPUT { COMPLETE FEATURE_TYPE GeometryReplacer_3_OUTPUT        $(GeometryReplacer_3_RemoveTempAttr) $(GeometryReplacer_3_RemoveSourceAttr) }    OUTPUT { REJECTED FEATURE_TYPE GeometryReplacer_3_<REJECTED>        $(GeometryReplacer_3_RemoveTempAttr) }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
