MACRO FeatureReader_2_OUTPUT_PORTS_ENCODED bygning_current
MACRO FeatureReader_2_DIRECTIVES COORDINATE_SYSTEM_KEY,25832,DECODE_TEXT_STRINGS,,EXPOSE_ATTRS_GROUP,,FEATURE_TYPE_KEY,bygning_current,FLATTEN_MODE,ALL_LEVELS,GEOMETRY_FORMAT,GeoJSON,GEOMETRY_KEY,geometri,JSON_EXPOSE_FORMAT_ATTRS,,QUERY_TABLE,bygning_current<space>json<lt>openbracket<gt><lt>quote<gt>features<lt>quote<gt><lt>closebracket<gt><lt>openbracket<gt>*<lt>closebracket<gt>,SAVE_FRAGMENTS,YES,SCAN_MODE,QUERY,USE_BASENAME_AS_DEFAULT_FEATURE_TYPE,,USE_SEARCH_ENVELOPE,NO
# Always provide an INTERACTION, otherwise the factory defaults to ENVELOPE_INTERSECTS
INCLUDE [if { ( {<Unused>} == {<Unused>} ) || ( {($INTERACT)} == {} ) } {             puts {MACRO FCTQUERY_INTERACTION_LINE FCTQUERY_INTERACTION NONE};          } else {             puts {MACRO FCTQUERY_INTERACTION_LINE FCTQUERY_INTERACTION "<Unused>"};          }         ]
# Consolidate the attribute merge options to what the factory expects
DEFAULT_MACRO FeatureReader_2_COMBINE_ATTRS
INCLUDE [       if { {RESULT_ONLY} == {MERGE} } {          puts "MACRO FeatureReader_2_COMBINE_ATTRS <Unused>";       } else {          puts "MACRO FeatureReader_2_COMBINE_ATTRS RESULT_ONLY";       };    ]
INCLUDE [    puts {DEFAULT_MACRO FeatureReaderDataset_FeatureReader_2 C:<backslash>Users<backslash>SEHHAN<backslash>OneDrive<space>-<space>Sweco<space>AB<backslash>FME<backslash>DAF2<backslash>WFS<backslash>BBR_WFS_download.json}; ]
