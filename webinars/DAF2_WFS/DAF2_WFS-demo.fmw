MACRO VertexCreator_3_RemoveSourceAttrX
MACRO VertexCreator_3_RemoveSourceAttrY
MACRO VertexCreator_3_RemoveSourceAttrZ
INCLUDE [ set sourceAttrX {@EvaluateExpression(FDIV,FLOAT,<at>Value<openparen>geometry.coordinates<opencurly>0<closecurly><closeparen>,VertexCreator_3)};           set sourceAttrY {@EvaluateExpression(FDIV,FLOAT,<at>Value<openparen>geometry.coordinates<opencurly>1<closecurly><closeparen>,VertexCreator_3)};           set sourceAttrZ {};           if {{No} == {Yes} } {                if {[regexp {@EvaluateExpression\(FDIV,FLOAT,<at>Value<openparen>(.*?)<closeparen>} "$sourceAttrX" dummy geomSrcAttrX]} {                   puts "MACRO VertexCreator_3_RemoveSourceAttrX @RemoveAttributes($geomSrcAttrX)";                };                if {[regexp {@EvaluateExpression\(FDIV,FLOAT,<at>Value<openparen>(.*?)<closeparen>} "$sourceAttrY" dummy geomSrcAttrY]} {                   puts "MACRO VertexCreator_3_RemoveSourceAttrY @RemoveAttributes($geomSrcAttrY)";                };                if {[regexp {@EvaluateExpression\(FDIV,FLOAT,<at>Value<openparen>(.*?)<closeparen>} "$sourceAttrZ" dummy geomSrcAttrZ]} {                   puts "MACRO VertexCreator_3_RemoveSourceAttrZ @RemoveAttributes($geomSrcAttrZ)";                };           }; ]
FACTORY_DEF {*} VertexCreatorFactory    FACTORY_NAME { VertexCreator_3 }    INPUT  FEATURE_TYPE FeatureReader_2_bygning_current    MODE { REPLACE }    INDEX { "<Unused>" }    CONTINUE_ON_ERROR YES    XVAL { "@EvaluateExpression(FDIV,FLOAT,<at>Value<openparen>geometry.coordinates<opencurly>0<closecurly><closeparen>,VertexCreator_3)" }    YVAL { "@EvaluateExpression(FDIV,FLOAT,<at>Value<openparen>geometry.coordinates<opencurly>1<closecurly><closeparen>,VertexCreator_3)" }    ZVAL { "" }    USE_EXISTING_Z YES    ALLOW_DUPLICATES { "<Unused>" }    CLOSE_LINES { "<Unused>" }    ADD_MODE_VERSION 6    MISSING_VAL_MODE { <Unused> }    COMPUTE_MEASURES_MODE { CONTINUOUS }    COMMAND_PARM_EVALUATION SINGLE_PASS    OUTPUT { REJECTED FEATURE_TYPE VertexCreator_3_<REJECTED>        }
# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {VertexCreator_3__Rejected__5684758d_e8e5_4db7_9d0a_796d8c1365d00} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME VertexCreator_3__Rejected_
