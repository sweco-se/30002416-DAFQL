MACRO VariableSetter_2_VAR vEndCursor
INCLUDE [    if {{Global} == {Local}} {       puts {MACRO VariableSetter_2_VAR $(WB_CURRENT_CONTEXT)_vEndCursor};    };    proc stripEvaluateExpression {val} {       if [regexp {@EvaluateExpression\([^)]*STRING_ENCODED,([^,]*),.+\)} $val -> unwrapped] {          return $unwrapped       } else {          return $val       };    };    set strippedValue [stripEvaluateExpression {@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>pageInfo.endCursor<closeparen>,VariableSetter_2)}];    puts "MACRO VariableSetter_2_VALUE $strippedValue"; ]
