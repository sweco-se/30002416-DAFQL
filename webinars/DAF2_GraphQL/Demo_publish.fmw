INCLUDE [    if {{OUTGOING} == {OUTGOING}} {       if {[string length {_gql_rest}] == 0} { return; };       set attrs [list {_gql_rest}];    } else {       set attrs [split {<Unused>} { }];    };    set clauses {};    foreach attr $attrs {       lappend clauses "ATTR";       lappend clauses "{";       lappend clauses $attr;       lappend clauses {"<opencurly><lf><space><space><quote>query<quote>:<space><quote><space><space><space><space><space><space><space><space><at>Value<openparen>_gql_rest<closeparen><quote><comma><lf><space><space><quote>variables<quote>:<space><opencurly><closecurly><lf><closecurly>"};       lappend clauses "}";    };    puts "MACRO StringConcatenator_2_eb6f2b4d_4d7c_48b3_8f70_db04291984650_ATTRS_TO_EVALUATE [join $clauses { }]"; ]
