# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {VariableSetter_5aa8f286_85b2_4af8_9da3_d93b9ab9ec2e0} ]
DEFAULT_MACRO WB_CURRENT_CONTEXT
MACRO VariableSetter_VAR vEndCursor
INCLUDE [    if {{Global} == {Local}} {       puts {MACRO VariableSetter_VAR $(WB_CURRENT_CONTEXT)_vEndCursor};    };    proc stripEvaluateExpression {val} {       if [regexp {@EvaluateExpression\([^)]*STRING_ENCODED,([^,]*),.+\)} $val -> unwrapped] {          return $unwrapped       } else {          return $val       };    };    set strippedValue [stripEvaluateExpression {@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>pageInfo.endCursor<closeparen>,VariableSetter)}];    puts "MACRO VariableSetter_VALUE $strippedValue"; ]
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { VariableSetter }    INPUT  FEATURE_TYPE Tester_PASSED_0_5lBjEqsEkCM=    ATTR_ACTION { "" $(FME_UUID_SAFE) SET_TO "$(VariableSetter_VALUE)" }    OUTPUT { OUTPUT FEATURE_TYPE VariableSetter_OUTPUT        @GlobalVariable($(VariableSetter_VAR),fme_attribute_name,$(FME_UUID_SAFE))        @RemoveAttributes($(FME_UUID_SAFE))         }
